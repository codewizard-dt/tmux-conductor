# =============================================================================
# tmux-conductor environment configuration (example)
# Copy to .env and fill in. Never commit real secrets.
#
# NOTE: app/api runs under `tsx watch`, which does NOT reload on .env changes.
#       After editing any app/api var, restart app/api manually.
# =============================================================================

# -----------------------------------------------------------------------------
# host-server (native tmux conductor)
# -----------------------------------------------------------------------------
# Fastify listen port for the native conductor host-server. Default 8788.
BACKEND_PORT=8788

# -----------------------------------------------------------------------------
# app/api (Fastify + better-auth, Postgres-backed)
# -----------------------------------------------------------------------------
# Fastify listen port for app/api. 8080 in prod, 8090 for local dev.
API_PORT=8080

# Allowed CORS origin(s) for app/api. Comma-separated for multiple origins.
# Defaults to http://localhost:${FRONTEND_PORT:-4321}.
CORS_ORIGIN=http://localhost:4321

# Postgres connection string for app/api (required).
# DO Managed PG: use the URL WITHOUT ?sslmode=require — db.ts pins the CA instead.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
# TLS to DO Managed PG is verified against deploy/do-ca-certificate.crt by default.
# Override the path, or pass the PEM inline (App Platform), if needed:
# DATABASE_CA_CERT_PATH=/app/deploy/do-ca-certificate.crt
# DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# better-auth signing secret, >=32 bytes (required). Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# URL app/api uses to reach the host-server. Default http://host.docker.internal:8788 (local Docker).
HOST_SERVER_URL=http://host.docker.internal:8788

# Google OAuth credentials. OAuth is disabled if either is unset.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Public base URL of the deployed app/api (for OAuth callbacks / better-auth).
PUBLIC_BASE_URL=http://localhost:8080

# Server-side admin email gate for app/api (the one account that bypasses the
# invite-code gate). MUST be set to the SAME email as VITE_ADMIN_EMAIL below —
# this is a dual-source admin gate, and the two values must match exactly.
BOOTSTRAP_ADMIN_EMAIL=you@example.com

# -----------------------------------------------------------------------------
# app/frontend (Vite)
# -----------------------------------------------------------------------------
# Vite dev server port. Default 4321.
FRONTEND_PORT=4321

# Public URL of the API for the frontend (build-time / runtime).
PUBLIC_API_URL=http://localhost:8080

# Frontend direct-mode API base override (app/frontend/src/lib/api.ts).
# Falls back to /api via the Vite proxy when unset.
VITE_API_URL=

# Vite dev proxy catch-all target (host-server). Default http://localhost:${BACKEND_PORT:-8788}.
PROXY_TARGET=http://localhost:8788

# Vite dev proxy target for app/api auth/pair/devices/invite-codes prefixes.
# Falls back to http://localhost:${API_PORT:-8080} when unset.
AUTH_PROXY_TARGET=

# Frontend admin email gate. MUST be set to the SAME email as BOOTSTRAP_ADMIN_EMAIL
# above (dual-source admin gate — the two values must match exactly).
VITE_ADMIN_EMAIL=you@example.com

# Frontend runtime API mode override (values: direct|relay). Auto-detected if unset.
# 'direct' uses the Vite proxy / VITE_API_URL; 'relay' routes conductor calls
# through app/api at /relay/<VITE_DEVICE_ID>/api.
VITE_API_MODE=

# Fallback device id for frontend relay mode; required when VITE_API_MODE=relay.
VITE_DEVICE_ID=

# -----------------------------------------------------------------------------
# deploy (App Platform / VPS)
# -----------------------------------------------------------------------------
# VPS/droplet IP used by deploy scripts (make deploy).
DROPLET_IP=
